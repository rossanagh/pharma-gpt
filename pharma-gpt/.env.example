# Copiază:  copy .env.example .env
# Nu comita .env în Git (conține secrete).
#
# IMPORTANT: acest fișier e doar exemplu — NU pune chei reale aici.

# Parolă pentru userul PostgreSQL pharma_app (aceeași pentru Spring și DBeaver)
POSTGRES_PASSWORD=schimba_cu_parola_ta_sigura

# Secret JWT — minim ~32 caractere, aleator, unic în producție
JWT_SECRET=generaza_un_secret_lung_si_aleator_minim_32

# OpenAI — chat „Întreabă AI”
OPENAI_API_KEY=sk-your-openai-key-here

# Opțional
# OPENAI_MODEL=gpt-4o-mini
